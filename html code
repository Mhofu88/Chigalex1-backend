<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Chigalex1 – Pi Network Pioneer Education Hub</title>
<script src="https://sdk.minepi.com/pi-sdk.js"></script>
<style>
  :root {
    --pi:#7B2D8B;--gold:#F5C518;--bg:#0D0A1A;--surface:#211A3A;
    --text:#F0EBF8;--text2:#B8A8D8;--warn:#FF7043;--accent:#00D4AA;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Sora',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
  #gate{position:fixed;inset:0;background:rgba(13,10,26,.97);display:flex;align-items:center;justify-content:center;padding:20px;}
  .box{background:var(--surface);border:1px solid rgba(123,45,139,.5);border-radius:24px;padding:40px;max-width:480px;width:100%;text-align:center;}
  .logo{width:72px;height:72px;background:linear-gradient(135deg,var(--pi),var(--gold));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:900;margin:0 auto 20px;}
  .btn{background:linear-gradient(135deg,var(--pi),var(--pi-l));color:#fff;border:none;padding:13px 24px;border-radius:100px;font-weight:700;width:100%;cursor:pointer;margin-top:12px;}
  .btn:disabled{opacity:0.5;cursor:not-allowed;}
  .err{color:var(--warn);margin-top:12px;font-size:.85rem;}
  #app{display:none;padding:40px 20px;text-align:center;}
</style>
</head>
<body>

<div id="gate">
  <div class="box">
    <div class="logo">π</div>
    <h2>Welcome to Chigalex1</h2>
    <p>Login with Pi and pay 1π to unlock training</p>
    
    <button class="btn" id="loginBtn" onclick="login()">🔐 Login with Pi</button>
    <div id="userInfo" style="display:none;margin-top:16px;"></div>
    <button class="btn" id="payBtn" style="display:none;" onclick="pay()">💳 Pay Membership Fee</button>
    <div class="err" id="err"></div>
  </div>
</div>

<div id="app">
  <h1>Welcome to Chigalex1 Training</h1>
  <p>You have access. Add your training content here.</p>
  <button class="btn" style="width:auto;" onclick="logout()">Logout</button>
</div>

<script>
const API_URL = "https://your-backend-url.com"; // Change this to your deployed backend URL
const MEMBERSHIP_AMOUNT = 1;
const MEMBERSHIP_MEMO = "Chigalex1 Membership";

let user = null;

Pi.init({ version: "2.0", sandbox: false }); // Set true for testing

async function login() {
  document.getElementById('loginBtn').disabled = true;
  try {
    const auth = await Pi.authenticate(['username', 'payments'], onIncompletePaymentFound);
    user = auth.user;
    document.getElementById('userInfo').style.display = 'block';
    document.getElementById('userInfo').innerHTML = `Logged in as <strong>@${user.username}</strong>`;
    document.getElementById('loginBtn').style.display = 'none';
    document.getElementById('payBtn').style.display = 'block';
    
    // Check if already paid
    checkMembership();
  } catch (err) {
    document.getElementById('err').textContent = "Login failed. Open in Pi Browser.";
    document.getElementById('loginBtn').disabled = false;
  }
}

async function checkMembership() {
  try {
    const res = await fetch(`${API_URL}/check-membership?username=${user.username}`);
    const data = await res.json();
    if (data.paid) enterApp();
  } catch (err) {
    console.log("Membership check failed");
  }
}

async function pay() {
  document.getElementById('payBtn').disabled = true;
  document.getElementById('err').textContent = '';
  
  const paymentData = {
    amount: MEMBERSHIP_AMOUNT,
    memo: MEMBERSHIP_MEMO,
    metadata: { username: user.username }
  };

  const callbacks = {
    onReadyForServerApproval: async (paymentId) => {
      // Approve payment
      await fetch(`${API_URL}/approve-payment`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ paymentId })
      });
    },
    onReadyForServerCompletion: async (paymentId, txid) => {
      // Complete payment and verify
      const res = await fetch(`${API_URL}/complete-payment`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ paymentId, txid, username: user.username })
      });
      const data = await res.json();
      if (data.success) enterApp();
      else {
        document.getElementById('err').textContent = "Payment verification failed";
        document.getElementById('payBtn').disabled = false;
      }
    },
    onCancel: () => {
      document.getElementById('err').textContent = "Payment cancelled";
      document.getElementById('payBtn').disabled = false;
    },
    onError: (error) => {
      document.getElementById('err').textContent = "Error: " + error;
      document.getElementById('payBtn').disabled = false;
    }
  };

  try {
    await Pi.createPayment(paymentData, callbacks);
  } catch (err) {
    document.getElementById('err').textContent = "Payment failed";
    document.getElementById('payBtn').disabled = false;
  }
}

function onIncompletePaymentFound(payment) {
  // Handle incomplete payments
  console.log("Incomplete payment:", payment);
}

function enterApp() {
  document.getElementById('gate').style.display = 'none';
  document.getElementById('app').style.display = 'block';
}

function logout() {
  localStorage.clear();
  location.reload();
}
</script>
</body>
</html> 

